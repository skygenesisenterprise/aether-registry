# Server Configuration
ENVIRONMENT=local  # local, staging, production
SERVER_PORT=8080
SERVER_URL=  # Optional: explicit server URL (overrides ENVIRONMENT detection)
GIN_MODE=debug

# JWT Configuration
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h
JWT_ISSUER=aether-account

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aether_account

# Logging
LOG_LEVEL=info
LOG_FILE=./src/logs/server.log
LOG_FORMAT=json

# Stalwart Mail Server
STALWART_HOST=localhost
STALWART_HTTP_PORT=8080
STALWART_JMAP_PORT=8081
STALWART_IMAP_PORT=993
STALWART_SMTP_PORT=587
STALWART_USE_TLS=true
STALWART_SKIP_VERIFY=false

# Mail Configuration
MAIL_PROVIDER=stalwart
IMAP_HOST=localhost
IMAP_PORT=993
IMAP_USE_TLS=true
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USE_TLS=true
POP3_HOST=localhost
POP3_PORT=995
POP3_USE_TLS=true
