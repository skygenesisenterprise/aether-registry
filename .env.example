# Development Environment Variables
# Copy this file to .env and modify as needed

# Environment
ENVIRONMENT=local
NODE_ENV=development

# Server
SERVER_PORT=8080
GIN_MODE=debug

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRY=24h
JWT_ISSUER=aether-account

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql://aether:password@postgres:5432/aether_account

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_ENVIRONMENT=local

# Logging
LOG_LEVEL=debug
LOG_FILE=./src/logs/server.log


# Service Key pour l'authentification des requêtes API banking
# Obtenez cette clé via POST /api/v1/service-keys (requires admin scope)
# Ou utilisez la clé par défaut générée au démarrage du serveur
NEXT_PUBLIC_SERVICE_KEY=sk_development_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx